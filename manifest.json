{
  "manifest_version": 3,
  "name": "Axoltl Session Handoff",
  "version": "0.1.0",
  "description": "Secure cross-provider and cross-device AI session handoff.",
  "icons": {
    "16": "assets/axoltl-icon-16.png",
    "32": "assets/axoltl-icon-32.png",
    "48": "assets/axoltl-icon-48.png",
    "128": "assets/axoltl-icon-128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://axoltl-relay.workers.dev/*",
    "https://axoltl-relay.example.workers.dev/*",
    "https://axoltl-relay.vishnu-tppr.workers.dev/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Axoltl",
    "default_icon": {
      "16": "assets/axoltl-icon-16.png",
      "32": "assets/axoltl-icon-32.png",
      "48": "assets/axoltl-icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/claude_scraper.js", "content/quota_detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content/openai_scraper.js", "content/quota_detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/quota_detector.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["crypto/noise.js", "libs/qrcode.min.js", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; style-src 'self' https://fonts.googleapis.com; font-src https://fonts.gstatic.com"
  }
}
