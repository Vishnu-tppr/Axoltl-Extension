{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": ["chrome-types"]
  },
  "include": ["popup/src/**/*.ts", "content/**/*.ts", "background/**/*.ts", "crypto/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}